# Copy this file to .env and fill in values.
# NEVER commit .env to git. The .gitignore already excludes it.

# ── Application ────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── PostgreSQL ─────────────────────────────────────────────────────────
POSTGRES_DB=txndb
POSTGRES_USER=txnuser
POSTGRES_PASSWORD=change_me_use_a_real_secret_here

# AsyncPG DSN for the app (must match above)
DATABASE_URL=postgresql+asyncpg://txnuser:change_me_use_a_real_secret_here@db:5432/txndb

# ── Redis ──────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_secret
REDIS_URL=redis://:change_me_redis_secret@redis:6379

# ── LLM ───────────────────────────────────────────────────────────────
# Get a free Gemini API key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ── File Upload ────────────────────────────────────────────────────────
UPLOAD_DIR=/tmp/txn_uploads
MAX_UPLOAD_BYTES=10485760
