APP_NAME=txn-pipeline
APP_ENV=development
LOG_LEVEL=INFO
REQUEST_ID_HEADER=X-Request-ID
# PostgreSQL (adjust host/port/user/password as needed)
DATABASE_URL=postgresql+asyncpg://txnuser:postgres123@db:5432/txndb
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800
# Redis broker / result backend
REDIS_URL=redis://:redis123@redis:6379
CELERY_BROKER_DB=0
CELERY_RESULT_DB=1
CELERY_RESULT_EXPIRES=86400
# File upload settings
UPLOAD_DIR=/tmp/txn_uploads
MAX_UPLOAD_BYTES=10485760
ALLOWED_MIME_TYPES=["text/csv","application/csv","text/plain"]
# Gemini LLM
GEMINI_API_KEY=AIzaSyCggGI1a60ESTXQE6NwbzgY_ZEsRtbxmsg
POSTGRES_PASSWORD=postgres123
REDIS_PASSWORD=redis123
POSTGRES_DB=txndb
POSTGRES_USER=txnuser
LLM_MODEL=gemini-1.5-flash
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048
LLM_BATCH_SIZE=20
LLM_RETRY_MAX=3
LLM_RETRY_BASE_DELAY=1.0
# Anomaly detection
ANOMALY_MULTIPLIER=3.0
